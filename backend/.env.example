# Logical DB 14 — dedicated to this app if you share one Redis instance (default has DBs 0–15).
REDIS_URL=redis://127.0.0.1:6379/14
STORAGE_ROOT=/tmp/audiobooks
# High | Medium — Ryan, LJSpeech, Cori (southern English stays low). Default Medium.
# PIPER_VOICE_QUALITY=High
# Piper via pip (piper-tts / OHF-Voice piper1-gpl). Model paths default to ~/.cache/audiobook-piper/
# PIPER_MODEL_PATH=/home/you/.cache/audiobook-piper/en_US-ryan-high.onnx
# PIPER_CONFIG_PATH=/home/you/.cache/audiobook-piper/en_US-ryan-high.onnx.json
CORS_ORIGINS=http://localhost:3000
# --- Optional: GitHub push webhook (POST /hooks/github/deploy) ---
# GITHUB_WEBHOOK_SECRET=same-as-github-webhook-secret
# GITHUB_WEBHOOK_SECRET_FILE=/opt/audiobook/deploy/github-webhook-secret.json
# DEPLOY_ROOT=/opt/audiobook
# DEPLOY_NOTIFY_URL=https://ntfy.sh/your-topic
# MEMORY_USAGE_DEBUG=false
